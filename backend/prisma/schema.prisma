// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x","debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Regresamos la URL aquí
}


enum StatusName {
  PENDIENTE
  EN_TRAMITE
  FINALIZADO
}

model Contact {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  phone     String?
  cedula    String    @unique
  servicios Service[] // Relación con la tabla Service
}

model Service {
  id          Int      @id @default(autoincrement())
  subject     String
  descripcion String
  createdAt   DateTime @default(now())
  
  // Relación con Contacto
  contact     Contact  @relation(fields: [contactId], references: [id])
  contactId   Int

  // Historial de estados (como hablamos antes)
  history     ServiceHistory[]
}


model ServiceHistory {
  id           Int        @id @default(autoincrement())
  status       StatusName
  createdAt    DateTime   @default(now())
  service      Service    @relation(fields: [serviceId], references: [id])
  serviceId    Int
  comment      String?    // Opcional: ¿por qué cambió el estado?
}

// NUEVO: Modelo para los usuarios del sistema (tú)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Aquí guardaremos el hash, nunca la clave plana
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}